# Optionally for dev
PORT=5001

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=your_aws_region

# S3 Bucket
S3_BUCKET_NAME=your_s3_bucket_name

# Number of days to retain emails in S3 before deleting (optional, omit to disable)
S3_RETENTION_DAYS=

# Mailbox path
MAILBOX_PATH=/home/user/server/mailbox

# Default email address to receive admin notifications (optional)
# Must already exist as a mailbox on the system — will not be created automatically
DEFAULT_EMAIL=